<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ahy.knowledgepulse.mapper.NoteFolderMapper">

    <select id="findByUserId" resultType="com.ahy.knowledgepulse.entity.NoteFolder">
        SELECT * FROM note_folder WHERE user_id = #{userId} ORDER BY create_time
    </select>

    <select id="findByParentId" resultType="com.ahy.knowledgepulse.entity.NoteFolder">
        SELECT * FROM note_folder WHERE user_id = #{userId} AND parent_id = #{parentId} ORDER BY create_time
    </select>

    <select id="findAllChildren" resultType="com.ahy.knowledgepulse.entity.NoteFolder">
        SELECT * FROM note_folder WHERE parent_id = #{parentId}
    </select>

    <select id="countNotesInFolder" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM note WHERE folder_id = #{folderId} AND is_deleted = 0
    </select>

    <select id="countChildFolders" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM note_folder WHERE parent_id = #{folderId}
    </select>

</mapper>
