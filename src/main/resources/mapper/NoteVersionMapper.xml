<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ahy.knowledgepulse.mapper.NoteVersionMapper">

    <select id="findByNoteId" resultType="com.ahy.knowledgepulse.entity.NoteVersion">
        SELECT * FROM note_version WHERE note_id = #{noteId} ORDER BY version DESC
    </select>

    <select id="getLatestVersion" resultType="java.lang.Integer">
        SELECT MAX(version) FROM note_version WHERE note_id = #{noteId}
    </select>

    <delete id="deleteByNoteId">
        DELETE FROM note_version WHERE note_id = #{noteId}
    </delete>

</mapper>
