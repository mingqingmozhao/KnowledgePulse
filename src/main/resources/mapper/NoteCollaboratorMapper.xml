<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ahy.knowledgepulse.mapper.NoteCollaboratorMapper">

    <select id="findByNoteId" resultType="com.ahy.knowledgepulse.entity.NoteCollaborator">
        SELECT * FROM note_collaborator WHERE note_id = #{noteId}
    </select>

    <select id="findResponsesByNoteId" resultType="com.ahy.knowledgepulse.dto.response.CollaboratorResponse">
        SELECT
            nc.id,
            nc.note_id AS noteId,
            nc.user_id AS userId,
            nc.permission,
            nc.create_time AS createTime,
            u.username,
            u.email,
            u.avatar,
            u.nickname
        FROM note_collaborator nc
        LEFT JOIN user u ON u.id = nc.user_id
        WHERE nc.note_id = #{noteId}
        ORDER BY nc.create_time ASC, nc.id ASC
    </select>

    <select id="findByUserId" resultType="com.ahy.knowledgepulse.entity.NoteCollaborator">
        SELECT * FROM note_collaborator WHERE user_id = #{userId}
    </select>

    <select id="findByNoteIdAndUserId" resultType="com.ahy.knowledgepulse.entity.NoteCollaborator">
        SELECT * FROM note_collaborator WHERE note_id = #{noteId} AND user_id = #{userId}
    </select>

    <delete id="deleteByNoteId">
        DELETE FROM note_collaborator WHERE note_id = #{noteId}
    </delete>

</mapper>
